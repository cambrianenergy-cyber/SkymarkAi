service cloud.firestore {
function isValidAttachment(a) {
  return a.name is string && a.url is string && a.type is string;
}
function isValidParticipant(p) {
  return p.type in ["contact", "user", "agent"] && p.id is string;
}
function isValidAction(action) {
  return action.type in ["create_task", "trigger_workflow", "notify", "assign_agent"] && action.config is map;
}
// Onboarding subcollection under workspace members
function isWorkspaceMember(workspaceId, uid) {
  // Checks if the user is a member of the workspace
  return request.auth != null &&
    exists(/databases/$(database)/documents/workspace_members/$(uid + '_' + workspaceId)) &&
    get(/databases/$(database)/documents/workspace_members/$(uid + '_' + workspaceId)).data.status == 'active';
}
function isServer() {
  // Only allow server (service account) writes
  return request.auth != null && request.auth.token.firebase.sign_in_provider == 'custom';
}
match /workspaces/{workspaceId}/members/{uid}/onboarding/{docId} {
  allow read: if isWorkspaceMember(workspaceId, uid);
  allow write: if isServer(); // 🔒 no client writes
}
// Steps subcollection under workflow_runs: Only admins can read/write
match /workflow_runs/{runId}/steps/{stepId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /admin_dashboards/{docId} {
  allow read, write: if isAdmin();
}
match /cost_usage_logs/{logId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /orchestrator_events/{eventId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /tool_registry/{toolId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /connections/{connectionId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /agent_tasks/{taskId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /subscriptions/{subscriptionId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /workflow_runs/{runId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
// Onboarding state: allow users to read/write their own onboarding state
match /onboarding_states/{userId} {
  allow read, write: if request.auth != null && request.auth.uid == userId;
}
// RBAC: Only allow users with roles other than 'viewer' to read/write sensitive collections
function userRole() {
  return request.auth != null ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : null;
}
function isFounder() { return userRole() == 'founder'; }
function isAdmin() { return userRole() == 'admin' || userRole() == 'founder' || userRole() == 'owner'; }
function isViewer() { return userRole() == 'viewer'; }

// Example: Sensitive collections
match /workspace_knowledge/{knowledgeId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /agent_memory/{memoryId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /admin_dashboards/{docId} {
  allow read, write: if isAdmin();
}
match /audit_logs/{logId} {
  allow read, create: if isAdmin();
  allow update, delete: if false;
}
match /cost_usage_logs/{logId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /orchestrator_events/{eventId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}

// Tool Registry/Tool Runs: Only founders/admins can access
match /tool_registry/{toolId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /tool_runs/{runId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}

// Agent/Workflow Management: Only founders/admins can manage
match /agents/{agentId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /workflows/{workflowId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}
match /agent_permissions/{agentId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}

// Billing/Subscription: Only founders/admins can access
match /subscriptions/{subscriptionId} {
  allow read, create, update: if isAdmin();
  allow delete: if false;
}

// User Profile Editing: Viewers can only read their own profile
match /users/{userId} {
  allow read: if request.auth != null && request.auth.uid == userId;
  allow create, update: if isAdmin() || (isViewer() && request.auth.uid == userId);
  allow delete: if false;
}

// No Write Access for Viewers: Viewers cannot write to any other collection
// (Handled by above rules; fallback below denies all)

// Workspace Settings: Only founders/admins can change
match /workspaces/{workspaceId} {
  // TEMPORARY: Allow public read access for testing
  allow read: if true;
  allow create, update: if isAdmin();
  allow delete: if false;
}

// Notification/Message Restrictions: Viewers can only see their own
match /notifications/{notificationId} {
  allow read: if isAdmin() || (isViewer() && request.auth.uid == resource.data.toUid);
  allow create, update: if isAdmin();
  allow delete: if false;
}
match /messages/{messageId} {
  allow read: if isAdmin() || (isViewer() && (resource.data.to.id == request.auth.uid || resource.data.from.id == request.auth.uid));
  allow create, update: if isAdmin();
  allow delete: if false;
}

// No Access to System Collections: Deny all for non-admins
match /system/{docId} {
  allow read, write: if isFounder();
}

// Deny all sensitive actions for viewers
// (You can add similar logic to other collections as needed)
// Tool registry - available tools and metadata
match /tool_registry/{toolId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.toolId is string &&
      request.resource.data.name is string &&
      request.resource.data.type in ["internal_api", "webhook", "integration", "llm_function", "email", "sms"] &&
      request.resource.data.enabled is bool &&
      request.resource.data.config is map &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}

// Tool runs - each tool execution instance
match /tool_runs/{runId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.runId is string &&
      request.resource.data.toolId is string &&
      request.resource.data.agentId is string &&
      request.resource.data.status in ["queued", "running", "succeeded", "failed"] &&
      (request.resource.data.input == null || request.resource.data.input is map) &&
      (request.resource.data.output == null || request.resource.data.output is map) &&
      (request.resource.data.error == null || request.resource.data.error is map) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}

// Execution failures - track failed executions
match /execution_failures/{failureId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.failureId is string &&
      request.resource.data.agentId is string &&
      request.resource.data.taskId is string &&
      request.resource.data.error is map &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}

// Cost usage logs - track LLM/tool costs
match /cost_usage_logs/{logId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.logId is string &&
      request.resource.data.agentId is string &&
      request.resource.data.type in ["llm", "tool", "workflow"] &&
      request.resource.data.amount is number &&
      request.resource.data.currency is string &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}

// Policy violations - log permission or policy errors
match /policy_violations/{violationId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.violationId is string &&
      request.resource.data.agentId is string &&
      request.resource.data.policy is map &&
      request.resource.data.error is map &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// Rate limits - stop runaway agents + enforce plan
match /rate_limits/{rateLimitId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.bucketId is string &&
      request.resource.data.windowStart is timestamp &&
      request.resource.data.count is number &&
      request.resource.data.limit is number &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// AI outputs - store AI deliverables separate from the entity
match /ai_outputs/{outputId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.outputId is string &&
      request.resource.data.type in ["email_draft", "sms_draft", "proposal", "summary", "ad_copy", "script", "report"] &&
      (request.resource.data.entityType == null || request.resource.data.entityType is string) &&
      (request.resource.data.entityId == null || request.resource.data.entityId is string) &&
      (request.resource.data.createdBy is map && request.resource.data.createdBy.type in ["agent", "user"] && request.resource.data.createdBy.id is string) &&
      request.resource.data.content is string &&
      request.resource.data.meta is map &&
      (request.resource.data.approvedAt == null || request.resource.data.approvedAt is timestamp) &&
      (request.resource.data.approvedByUid == null || request.resource.data.approvedByUid is string) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// Messages - message log, agent replies, audit
match /messages/{messageId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.messageId is string &&
      request.resource.data.threadId is string &&
      request.resource.data.direction in ["inbound", "outbound"] &&
      (request.resource.data.from is map && request.resource.data.from.type in ["contact", "user", "agent", "system"] && (request.resource.data.from.id == null || request.resource.data.from.id is string)) &&
      (request.resource.data.to is map && request.resource.data.to.type in ["contact", "user", "agent", "system"] && (request.resource.data.to.id == null || request.resource.data.to.id is string)) &&
      request.resource.data.body is string &&
      request.resource.data.attachments is list &&
      request.resource.data.attachments.hasOnly(map) &&
      request.resource.data.attachments.all(isValidAttachment) &&
      request.resource.data.status in ["sent", "delivered", "read", "failed", "queued"] &&
      request.resource.data.createdAt is timestamp
    );
  allow delete: if false;
}
// Threads - conversation threads per channel
match /threads/{threadId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.threadId is string &&
      request.resource.data.channelId is string &&
      (request.resource.data.entityType == null || request.resource.data.entityType is string) &&
      (request.resource.data.entityId == null || request.resource.data.entityId is string) &&
      request.resource.data.status in ["open", "pending", "closed"] &&
      (request.resource.data.lastMessageAt == null || request.resource.data.lastMessageAt is timestamp) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      request.resource.data.participants is list &&
      request.resource.data.participants.size() > 0 &&
      request.resource.data.participants.hasOnly(map) &&
      request.resource.data.participants.all(isValidParticipant)
    );
  allow delete: if false;
}
// Channels - unified inbox foundation
match /channels/{channelId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.channelId is string &&
      request.resource.data.type in ["email", "sms", "webchat", "instagram", "facebook", "whatsapp"] &&
      (request.resource.data.address == null || request.resource.data.address is string) &&
      request.resource.data.connected is bool &&
      request.resource.data.settings is map &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// Orchestrator rules - event-driven automation rules
match /orchestrator_rules/{ruleId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.ruleId is string &&
      request.resource.data.name is string &&
      request.resource.data.enabled is bool &&
      request.resource.data.eventType is string &&
      request.resource.data.conditions is map &&
      request.resource.data.actions is list &&
      request.resource.data.actions.size() > 0 &&
      request.resource.data.actions.hasOnly(map) &&
      request.resource.data.actions.all(isValidAction) &&
      (request.resource.data.cooldownSeconds == null || request.resource.data.cooldownSeconds is number) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// Orchestrator events - event-driven automation backbone
match /orchestrator_events/{eventId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.eventId is string &&
      request.resource.data.type is string &&
      request.resource.data.payload is map &&
      request.resource.data.status in ["new", "processed", "failed", "dead"] &&
      request.resource.data.createdAt is timestamp &&
      (request.resource.data.processedAt == null || request.resource.data.processedAt is timestamp) &&
      request.resource.data.attempts is number &&
      (request.resource.data.lastError == null || (request.resource.data.lastError is map && request.resource.data.lastError.code is string && request.resource.data.lastError.message is string))
    );
  allow delete: if false;
}
// Agent tasks - agent to-do list queue
match /agent_tasks/{taskId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.taskId is string &&
      request.resource.data.agentId is string &&
      request.resource.data.title is string &&
      (request.resource.data.description == null || request.resource.data.description is string) &&
      request.resource.data.priority in ["low", "normal", "high", "urgent"] &&
      request.resource.data.status in ["queued", "assigned", "running", "done", "failed", "canceled"] &&
      (request.resource.data.entityType == null || request.resource.data.entityType is string) &&
      (request.resource.data.entityId == null || request.resource.data.entityId is string) &&
      (request.resource.data.dueAt == null || request.resource.data.dueAt is timestamp) &&
      (request.resource.data.lockedByRunId == null || request.resource.data.lockedByRunId is string) &&
      (request.resource.data.createdBy is map && request.resource.data.createdBy.type in ["user", "agent", "system"] && (request.resource.data.createdBy.id == null || request.resource.data.createdBy.id is string)) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      request.resource.data.attempts is number &&
      (request.resource.data.lastError == null || (request.resource.data.lastError is map && request.resource.data.lastError.code is string && request.resource.data.lastError.message is string))
    );
  allow delete: if false;
}
// Agent tools - which tools exist + per-agent enablement
match /agent_tools/{toolId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.toolId is string &&
      request.resource.data.name is string &&
      request.resource.data.type in ["internal_api", "webhook", "integration", "llm_function", "email", "sms"] &&
      request.resource.data.enabled is bool &&
      request.resource.data.config is map &&
      (request.resource.data.allowedAgents == null || request.resource.data.allowedAgents is list) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// Agent memory - controlled memory
match /agent_memory/{memoryId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.memoryId is string &&
      (request.resource.data.agentId == null || request.resource.data.agentId is string) &&
      (request.resource.data.entityType == null || request.resource.data.entityType is string) &&
      (request.resource.data.entityId == null || request.resource.data.entityId is string) &&
      request.resource.data.type in ["fact", "preference", "summary", "instruction", "warning"] &&
      request.resource.data.content is string &&
      request.resource.data.source in ["user", "agent", "system"] &&
      request.resource.data.confidence is number &&
      (request.resource.data.expiresAt == null || request.resource.data.expiresAt is timestamp) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// Agent permissions - explicit policy for server-side checks
match /agent_permissions/{agentId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.agentId is string &&
      request.resource.data.policyVersion is number &&
      request.resource.data.canRead is list &&
      request.resource.data.canWrite is list &&
      request.resource.data.canDelete is list &&
      request.resource.data.canMessage is bool &&
      request.resource.data.canTriggerWorkflows is bool &&
      request.resource.data.allowedEntityTypes is list &&
      (request.resource.data.dataScopes == null || (request.resource.data.dataScopes is map && (request.resource.data.dataScopes.fieldAllowlist == null || request.resource.data.dataScopes.fieldAllowlist is list) && (request.resource.data.dataScopes.fieldDenylist == null || request.resource.data.dataScopes.fieldDenylist is list))) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      (request.resource.data.updatedByUid == null || request.resource.data.updatedByUid is string)
    );
  allow delete: if false;
}
// Agent runs - each agent execution is separately tracked
match /agent_runs/{agentRunId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.agentRunId is string &&
      request.resource.data.agentId is string &&
      request.resource.data.status in ["queued", "running", "succeeded", "failed", "canceled"] &&
      (request.resource.data.reason == null || request.resource.data.reason is string) &&
      (request.resource.data.input is map && (request.resource.data.input.entityType == null || request.resource.data.input.entityType is string) && (request.resource.data.input.entityId == null || request.resource.data.input.entityId is string) && request.resource.data.input.payload is map) &&
      (request.resource.data.output == null || (request.resource.data.output is map && (request.resource.data.output.summary == null || request.resource.data.output.summary is string) && (request.resource.data.output.payload == null || request.resource.data.output.payload is map))) &&
      (request.resource.data.startedAt == null || request.resource.data.startedAt is timestamp) &&
      (request.resource.data.endedAt == null || request.resource.data.endedAt is timestamp) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      (request.resource.data.runContext == null || (request.resource.data.runContext is map && (request.resource.data.runContext.workflowRunId == null || request.resource.data.runContext.workflowRunId is string) && (request.resource.data.runContext.channelId == null || request.resource.data.runContext.channelId is string) && (request.resource.data.runContext.threadId == null || request.resource.data.runContext.threadId is string))) &&
      (request.resource.data.errors == null || (request.resource.data.errors is list && request.resource.data.errors.size() <= 100 && request.resource.data.errors.hasOnly(map))) &&
      (request.resource.data.usage == null || (request.resource.data.usage is map && (request.resource.data.usage.tokensIn == null || request.resource.data.usage.tokensIn is number) && (request.resource.data.usage.tokensOut == null || request.resource.data.usage.tokensOut is number) && (request.resource.data.usage.cost == null || request.resource.data.usage.cost is number)))
    );
  allow delete: if false;
}
// Workspaces - tenant boundary
match /workspaces/{workspaceId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.name is string &&
      request.resource.data.ownerUid is string &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      request.resource.data.status in ["active", "suspended", "deleted"] &&
      // Recommended fields
      (request.resource.data.industry == null || request.resource.data.industry is string) &&
      (request.resource.data.timezone == null || request.resource.data.timezone is string) &&
      (request.resource.data.billingAccountId == null || request.resource.data.billingAccountId is string) &&
      (request.resource.data.settings == null || request.resource.data.settings is map)
    );
  allow delete: if false;
}
// Workspace members - RBAC
match /workspace_members/{memberId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.uid is string &&
      request.resource.data.role in ["owner", "admin", "member", "viewer"] &&
      request.resource.data.status in ["active", "invited", "removed"] &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      // Recommended fields
      (request.resource.data.invitedByUid == null || request.resource.data.invitedByUid is string) &&
      (request.resource.data.permissions == null || request.resource.data.permissions is list)
    );
  allow delete: if false;
}
// Contacts - universal relationship object
match /contacts/{contactId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.contactId is string &&
      request.resource.data.name is string &&
      (request.resource.data.email == null || request.resource.data.email is string) &&
      (request.resource.data.phone == null || request.resource.data.phone is string) &&
      request.resource.data.tags is list &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      // Recommended fields
      (request.resource.data.source == null || request.resource.data.source in ["manual", "import", "webhook", "agent"]) &&
      (request.resource.data.ownerUid == null || request.resource.data.ownerUid is string) &&
      (request.resource.data.linkedEntity == null || (request.resource.data.linkedEntity is map && request.resource.data.linkedEntity.type is string && request.resource.data.linkedEntity.id is string))
    );
  allow delete: if false;
}
// Leads - pipeline + agent actions
match /leads/{leadId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.leadId is string &&
      request.resource.data.title is string &&
      request.resource.data.status in ["new", "working", "won", "lost", "archived"] &&
      (request.resource.data.stage == null || request.resource.data.stage is string) &&
      (request.resource.data.contactId == null || request.resource.data.contactId is string) &&
      (request.resource.data.assignedToUid == null || request.resource.data.assignedToUid is string) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      // Recommended fields
      (request.resource.data.value == null || request.resource.data.value is number) &&
      (request.resource.data.nextActionAt == null || request.resource.data.nextActionAt is timestamp) &&
      (request.resource.data.lastTouchAt == null || request.resource.data.lastTouchAt is timestamp) &&
      (request.resource.data.channelThreadId == null || request.resource.data.channelThreadId is string)
    );
  allow delete: if false;
}
// Jobs - delivery entity
match /jobs/{jobId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.jobId is string &&
      request.resource.data.status in ["draft", "active", "paused", "completed", "canceled"] &&
      (request.resource.data.leadId == null || request.resource.data.leadId is string) &&
      (request.resource.data.contactId == null || request.resource.data.contactId is string) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// Estimates - money object
match /estimates/{estimateId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.estimateId is string &&
      (request.resource.data.jobId == null || request.resource.data.jobId is string) &&
      (request.resource.data.leadId == null || request.resource.data.leadId is string) &&
      request.resource.data.status in ["draft", "sent", "accepted", "rejected", "expired"] &&
      request.resource.data.subtotal is number &&
      request.resource.data.tax is number &&
      request.resource.data.total is number &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// Documents - storage + compliance
match /documents/{documentId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.documentId is string &&
      request.resource.data.entityType is string &&
      request.resource.data.entityId is string &&
      request.resource.data.title is string &&
      request.resource.data.type is string &&
      request.resource.data.storagePath is string &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// Agents - governed operator definitions
match /agents/{agentId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.agentId is string &&
      request.resource.data.name is string &&
      request.resource.data.category is string &&
      request.resource.data.status in ["active", "paused", "archived"] &&
      request.resource.data.instructions is string &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      // Must add
      (request.resource.data.authority is map && request.resource.data.authority.canRead is list && request.resource.data.authority.canWrite is list && request.resource.data.authority.canMessage is bool && request.resource.data.authority.canTriggerWorkflows is bool) &&
      (request.resource.data.constraints is map && request.resource.data.constraints.maxSteps is number && request.resource.data.constraints.maxToolCalls is number && request.resource.data.constraints.allowExternalSend is bool)
    );
  allow delete: if false;
}
// Workflows - the operating system
match /workflows/{workflowId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.workflowId is string &&
      request.resource.data.name is string &&
      request.resource.data.status in ["active", "paused", "archived"] &&
      request.resource.data.steps is list &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      // Must add
      (request.resource.data.completionRules is map && request.resource.data.completionRules.successCriteria is string && request.resource.data.completionRules.failCriteria is string) &&
      (request.resource.data.requiredPermissions is list)
    );
  allow delete: if false;
}
// Workflow runs - audit-able execution trail
match /workflow_runs/{runId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.runId is string &&
      request.resource.data.workflowId is string &&
      request.resource.data.status in ["queued", "running", "succeeded", "failed", "canceled", "partial"] &&
      (request.resource.data.startedAt == null || request.resource.data.startedAt is timestamp) &&
      (request.resource.data.endedAt == null || request.resource.data.endedAt is timestamp) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp &&
      // Must add
      (request.resource.data.trigger is map &&
        request.resource.data.trigger.type in ["manual", "event", "schedule", "agent"] &&
        (request.resource.data.trigger.byUid == null || request.resource.data.trigger.byUid is string) &&
        (request.resource.data.trigger.byAgentId == null || request.resource.data.trigger.byAgentId is string)
      ) &&
      (request.resource.data.cursor == null || (request.resource.data.cursor is map && request.resource.data.cursor.stepIndex is number && request.resource.data.cursor.state is map)) &&
      (request.resource.data.metrics == null || (request.resource.data.metrics is map && request.resource.data.metrics.stepsCompleted is number && (request.resource.data.metrics.tokens == null || request.resource.data.metrics.tokens is number) && (request.resource.data.metrics.cost == null || request.resource.data.metrics.cost is number)))
    );
  allow delete: if false;
}
// Audit logs - immutable-ish record
match /audit_logs/{logId} {
  allow read: if isSignedIn();
  allow create: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.logId is string &&
      request.resource.data.actorType in ["user", "agent", "system"] &&
      request.resource.data.actorId is string &&
      request.resource.data.action is string &&
      request.resource.data.entityType is string &&
      request.resource.data.entityId is string &&
      request.resource.data.createdAt is timestamp &&
      (request.resource.data.before == null || request.resource.data.before is map) &&
      (request.resource.data.after == null || request.resource.data.after is map) &&
      (request.resource.data.ip == null || request.resource.data.ip is string) &&
      (request.resource.data.userAgent == null || request.resource.data.userAgent is string)
    );
  allow update, delete: if false;
}
// Notifications - system messaging
match /notifications/{notificationId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      request.resource.data.workspaceId is string &&
      request.resource.data.notificationId is string &&
      request.resource.data.toUid is string &&
      request.resource.data.type is string &&
      request.resource.data.title is string &&
      request.resource.data.body is string &&
      (request.resource.data.readAt == null || request.resource.data.readAt is timestamp) &&
      request.resource.data.createdAt is timestamp
    );
  allow delete: if false;
}
// Subscriptions - plan gating must be server-enforced
match /subscriptions/{subscriptionId} {
  allow read: if isSignedIn();
  allow create, update: if isSignedIn() &&
    (
      // Required fields
      request.resource.data.workspaceId is string &&
      request.resource.data.plan in ["starter", "pro", "enterprise"] &&
      request.resource.data.status in ["active", "trialing", "past_due", "canceled"] &&
      (request.resource.data.stripeCustomerId == null || request.resource.data.stripeCustomerId is string) &&
      (request.resource.data.stripeSubscriptionId == null || request.resource.data.stripeSubscriptionId is string) &&
      (request.resource.data.currentPeriodEnd == null || request.resource.data.currentPeriodEnd is timestamp) &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.updatedAt is timestamp
    );
  allow delete: if false;
}
// Social connection docs: readable by workspace members, writable by admins
match /workspaces/{workspaceId}/integrations/{platform}/connections/{uid} {
  allow read: if isWorkspaceMember(workspaceId, request.auth.uid);
  allow write: if isWorkspaceAdmin(workspaceId, request.auth.uid);
}


// Absolutely deny all client access to secret tokens
match /secrets/{tokenRef} {
  allow read: if false;
  allow write: if false;
}
}

